// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  GROOMER
  RECEPTIONIST
  CLIENT
}

model Users {
  id        String @id @default(cuid())
  name      String?
  email     String @unique
  password  String

  // usar enum, NO string
  role      Role @default(CLIENT)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  lastLogin DateTime?

  isVerified Boolean @default(false)

  // Cantidad de intentos fallidos consecutivos
  failedLoginAttempts Int @default(0)

  // Hasta cuándo está bloqueada la cuenta
  lockedUntil DateTime?

  // Último intento fallido (opcional pero útil)
  lastFailedLoginAt DateTime?

  // RELACIONES INVERSAS
  emailVerification EmailVerification[]

  clientProfile Client?
  staffProfile  Staff?

  // LOGS DE AUDITORÍA  
  auditLogs AuditLog[]  
}

model Client {
  userId  String @id
  phone   String?
  ci      String? @unique
  address String?

  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum StaffType {
  GROOMER
  RECEPTIONIST
}

model Staff {
  userId    String @id
  staffType StaffType

  specialty String?
  shift     String?
  phone     String?

  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerification {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())

  userId      String?
  user        Users?   @relation(fields: [userId], references: [id])

  role        Role?
  action      String

  entityType  String?
  entityId    String?

  metadata    Json?

  // Dirección IP del usuario  
ipAddress String?  
  
// Navegador / dispositivo / sistema operativo  
// obtenido desde el header HTTP "User-Agent"
  userAgent   String?

  success     Boolean @default(true)

  createdAt   DateTime @default(now())
}